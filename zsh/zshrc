# Environment Variables
export LC_ALL="en_US.UTF-8" \
       LANG="en_US.UTF-8" \
       EDITOR='nvim' \
       VISUAL='nvim' \
       DOTFILES="$HOME/.dotfiles" \
       ZSH="$HOME/.oh-my-zsh" \
       PATH="$PATH:$HOME/.local/bin"

# Optimize ZSH
if [[ "$ZPROF" = true ]]; then
  zmodload zsh/zprof
  zprof
fi

# Disable flow control to prevent accidental terminal hangups
stty -ixon

# Plugin Configuration
plugins=(
  git
  zsh-autosuggestions
  zsh-syntax-highlighting
  colorize
  copypath
  copyfile
  dnf
)

# Setup Oh My Zsh
ZSH_THEME="dbox"
source "$ZSH/oh-my-zsh.sh"

# Setup history, zsh styles, and aliases
. $DOTFILES/zsh/hist.zsh
. $DOTFILES/zsh/zstyles.zsh
. $DOTFILES/zsh/aliases.zsh