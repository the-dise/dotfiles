# vim: ft=zsh

alias ..="cd .."

# Alias Oh My Zsh
alias zshconf="vim ~/.zshrc && exec zsh"
alias ohmyzsh="vim ~/.oh-my-zsh"

# Git
alias gs="git status"
alias gp="git pull"
alias gb="git branch"
alias ga="git add ."
alias gc="git commit -m $1"


# Colorify
alias l='exa'
alias ls='exa -l'
alias lsa='exa -la'

alias grep='grep --color=auto --exclude-dir={.bzr,CVS,.git,.hg,.svn} --exclude-dir={.bundle,node_modules}'

alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# https://github.com/yt-dlp/yt-dlp
alias yt='yt-dlp --add-metadata -ic' # Download video
alias yta='yt-dlp --add-metadata -xic' # Download audio

# https://github.com/sharkdp/bat
alias cat='bat'

# tmux sessions
alias tas="tmux attach-session -t $1"
alias tns="tmux new-session -s $1"
